---
import { Label } from "@/shared/components/ui/label";
import { Input } from "@/shared/components/ui/input";
import { Button } from "@/shared/components/ui/button";
import { Mail, ArrowRight, Info } from "lucide-react";
---

<form class="space-y-6" id="forgot-password-form">
  <div class="space-y-2">
    <Label htmlFor="email" className="text-foreground font-medium">
      Correo electrónico
    </Label>
    <div class="relative">
      <Mail
        className="absolute left-3 top-1/2 transform -translate-y-1/2 text-muted-foreground h-4 w-4"
      />
      <Input
        id="email"
        type="email"
        placeholder="tu@email.com"
        className="pl-10 bg-input border-border/50 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20"
        required
      />
    </div>
    <p class="text-xs text-muted-foreground">
      Ingresa el correo asociado a tu cuenta de Lazarus
    </p>
  </div>

  <Button
    type="submit"
    className="w-full bg-primary hover:bg-primary/90 text-primary-foreground font-medium py-2.5 transition-all duration-200 group"
  >
    <div class="flex items-center justify-center" id="button-content">
      Enviar enlace de restablecimiento
      <ArrowRight
        className="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform"
      />
    </div>
  </Button>

  <div class="bg-muted/30 border border-border/30 rounded-lg p-4">
    <div class="flex items-start space-x-3">
      <Info className="w-5 h-5 mr-2" />
      <div>
        <h4 class="text-sm font-medium text-foreground mb-1">
          ¿No recibes el correo?
        </h4>
        <ul class="text-xs text-muted-foreground space-y-1">
          <li>• Revisa tu carpeta de spam</li>
          <li>• Verifica que el correo sea correcto</li>
          <li>• Espera unos minutos, puede tardar</li>
        </ul>
      </div>
    </div>
  </div>
</form>

<script>
  import { PUBLIC_API_URL } from "astro:env/client";
  import { toast } from "sonner";

  const form = document.getElementById(
    "forgot-password-form"
  ) as HTMLFormElement;
  const buttonContent = document.getElementById(
    "button-content"
  ) as HTMLDivElement;
  const originalButtonContent = buttonContent.innerHTML;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    buttonContent.innerHTML = "Enviando...";

    const email = (document.getElementById("email") as HTMLInputElement).value;

    try {
      const response = await fetch(`${PUBLIC_API_URL}auths/forgot-password`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ email }),
      });
      const data = await response.json();

      if (response.ok) {
        return toast.success(data.message);
      } else {
        return toast.error(data.detail);
      }
    } catch (error) {
      console.error("Error:", error);
      toast.error("Error al enviar el enlace de restablecimiento.", {
        description:
          "No se pudo conectar con el servidor. Inténtalo de nuevo más tarde.",
      });
    } finally {
      buttonContent.innerHTML = originalButtonContent;
    }
  });
</script>
