---
import { Badge } from "@/shared/components/ui/badge";
import { Button } from "@/shared/components/ui/button";
import { Card } from "@/shared/components/ui/card";
import { Plug, Check, ExternalLink } from "lucide-react";

const integrations = [
  {
    name: "Google Calendar",
    description: "Sincroniza tus citas con Google Calendar",
    icon: "📅",
    connected: true,
    status: "Activo",
  },
  {
    name: "Zoom",
    description: "Realiza consultas virtuales con Zoom",
    icon: "🎥",
    connected: true,
    status: "Activo",
  },
  {
    name: "Slack",
    description: "Recibe notificaciones en Slack",
    icon: "💬",
    connected: false,
    status: "No conectado",
  },
  {
    name: "Microsoft Teams",
    description: "Integra con Microsoft Teams para videollamadas",
    icon: "👥",
    connected: false,
    status: "No conectado",
  },
  {
    name: "Stripe",
    description: "Procesa pagos con Stripe",
    icon: "💳",
    connected: true,
    status: "Activo",
  },
  {
    name: "Twilio",
    description: "Envía SMS y notificaciones",
    icon: "📱",
    connected: false,
    status: "No conectado",
  },
];
---

<Card id="integrations" className="p-6 scroll-mt-24">
  <div class="space-y-6">
    <div>
      <h2 class="text-xl font-semibold text-foreground">Integraciones</h2>
      <p class="text-sm text-muted-foreground mt-1">
        Conecta Lazarus con tus herramientas favoritas
      </p>
    </div>

    <div class="grid gap-4">
      {
        integrations.map((integration) => (
          <div class="flex items-center justify-between p-4 rounded-lg border border-border bg-card hover:bg-card/80 transition-colors">
            <div class="flex items-center gap-4">
              <div class="text-3xl">{integration.icon}</div>
              <div>
                <div class="flex items-center gap-2">
                  <h3 class="font-medium text-foreground">
                    {integration.name}
                  </h3>
                  {integration.connected && (
                    <Badge variant="secondary" className="gap-1">
                      <Check className="h-3 w-3" />
                      Conectado
                    </Badge>
                  )}
                </div>
                <p class="text-sm text-muted-foreground">
                  {integration.description}
                </p>
              </div>
            </div>

            <div class="flex items-center gap-2">
              {integration.connected ? (
                <>
                  <Button variant="outline" size="sm">
                    Configurar
                  </Button>
                  <Button
                    variant="ghost"
                    size="sm"
                    className="text-destructive"
                  >
                    Desconectar
                  </Button>
                </>
              ) : (
                <Button size="sm" className="gap-2">
                  <Plug className="h-4 w-4" />
                  Conectar
                </Button>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <div class="pt-4 border-t border-border">
      <Button variant="outline" className="gap-2 bg-transparent">
        <ExternalLink className="h-4 w-4" />
        Explorar Más Integraciones
      </Button>
    </div>
  </div>
</Card>
