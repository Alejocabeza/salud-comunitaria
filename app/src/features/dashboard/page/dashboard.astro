---
import ActivitySection from "../components/dashboard/ActivitySection.astro";
import OverviewSection from "../components/dashboard/OverviewSection.astro";
import PatientMetrics from "../components/dashboard/PatientMetrics.tsx";
import ProgramsSection from "../components/dashboard/ProgramsSection.astro";
import ResourceSection from "../components/dashboard/ResourceSection.astro";
---

<div class="flex-1 space-y-6 p-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Panel de Control</h1>
      <p class="text-muted-foreground">
        Centro Comunitario de Salud - Vista General
      </p>
    </div>
    <div class="flex items-center gap-2">
      <select
        class="bg-input border border-border rounded-md px-3 py-2 text-sm"
      >
        <option>Últimas 24 horas</option>
        <option>Última semana</option>
        <option>Último mes</option>
      </select>
    </div>
  </div>
  <OverviewSection />
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <PatientMetrics client:load />
      <ProgramsSection />
    </div>
    <div class="space-y-6">
      <ResourceSection />
      <ActivitySection />
    </div>
  </div>
</div>
